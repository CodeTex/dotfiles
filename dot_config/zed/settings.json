{
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha",
  },
  "theme": {
    "mode": "dark",
    "light": "Rosé Pine Dawn",
    "dark": "Catppuccin Macchiato",
  },
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 10,
  "ui_font_family": "Roboto",
  "ui_font_size": 12,
  "vim_mode": false,
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff", "!basedpyright"],
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true,
      },
    },
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_size": 10,
  },
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "agent_buffer_font_size": 10,
  "agent_ui_font_size": 12,
  "disable_ai": false,
  "edit_predictions": {
    "provider": "copilot",
  },
}
