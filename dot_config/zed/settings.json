{
  // AI
  "agent": {
    "commit_message_model": {
      "model": "qwen3.5:4b",
      "provider": "ollama",
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "plan",
        "model": "ollama/qwen3.6:35b"
      },
      "type": "registry"
    }
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "copilot",
  },
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "auto_discover": true,
      "context_window": 4096,
    },
    "opencode": {
      "show_free_models": true,
      "show_go_models": false,
      "show_zen_models": false,
    },
  },

  // Appearance
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 10,
  "icon_theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "dark",
  },
  "theme": {
    "dark": "Catppuccin Macchiato",
    "light": "Nord Light",
    "mode": "dark",
  },
  "ui_font_family": "Roboto",
  "ui_font_size": 13,

  // Debugging
  "debugger": {
    "timeout": 10000,
  },

  // Editor
  "auto_indent_on_paste": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 5000,
    },
  },
  "cursor_shape": "hollow",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "extend_comment_on_newline": false,
  "format_on_save": "off",
  "gutter": {
    "line_numbers": true,
    "min_line_number_digits": 0,
  },
  "horizontal_scroll_margin": 1,
  "hover_popover_enabled": true,
  "inline_code_actions": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "relative_line_numbers": "enabled",
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "vertical_scroll_margin": 1,
  "vim_mode": false,

  // General
  "auto_update": false,
  "restore_on_file_reopen": false,
  "restore_on_startup": "empty_tab",
  "session": {
    "restore_unsaved_buffers": false,
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },

  // Panels
  "collaboration_panel": {
    "button": false,
    "dock": null,
  },
  "git_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 300,
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "left",
    "default_width": 300,
    "hide_root": true,
    "starts_open": false,
  },

  // Languages / LSP
  "languages": {
    "Dockerfile": {
      "language_servers": [
        "docker-language-server",
        "dockerfile-language-server",
      ],
      "wrap_guides": [100],
    },
    "Markdown": {
      "format_on_save": "on",
      "wrap_guides": [200],
    },
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true,
      },
      "format_on_save": "on",
      "language_servers": ["ty", "ruff", "!basedpyright"],
      "wrap_guides": [90],
    },
    "TOML": {
      "wrap_guides": [80],
    },
    "YAML": {
      "language_servers": ["yaml-language-server"],
      "wrap_guides": [100],
    },
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/Nuitka/Nuitka/c4b663ccd79f6a89463fdb9a7a3ff1599ef05803/nuitka/package_config/nuitka-package-config-schema.json": "*.nuitka-package.config.yml",
          },
        },
      },
    },
  },

  // Search & Files
  "file_finder": {
    "file_icons": true,
    "modal_max_width": "medium",
  },

  // Terminal
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
  },

  // Version Control
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "delay_ms": 500,
      "enabled": true,
    },
  },

  // Window & Layout
  "status_bar": {
    "experimental.show": true,
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": true,
    "show_branch_status_icon": true,
    "show_user_menu": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
}
