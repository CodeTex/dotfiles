{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5-mini",
  "autoupdate": true,
  "share": "disabled",
  "permission": {
    "*": "ask",
    "grep": "allow",
    "glob": "allow",
    "edit": "allow",
    "lsp": "ask",
    "skill": "allow",
    "todo*": "allow",
    "web*": "allow",
    "task": "allow",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",

      // --- Allow: file and search inspection ---
      "ls *": "allow",
      "dir *": "allow",
      "eza *": "allow",
      "fd *": "allow",
      "rg *": "allow",

      // --- Allow: git read-only ---
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",

      // --- Allow: Python quality checks ---
      "uv run pytest*": "allow",
      "uv run ruff*": "allow",
      "uv run ty*": "allow",
      "uvx *": "allow",
      ".venv\\Scripts\\python*": "allow",
      ".venv\\Scripts\\prek*": "allow",
      ".venv/bin/python*": "allow",
      ".venv/bin/prek*": "allow",
      "*python -m pytest*": "allow",
      "pytest*": "allow",
      "*python -m ruff*": "allow",
      "ruff*": "allow",
      "*python -m ty*": "allow",
      "prek *": "allow",
      "ty*": "allow",

      // --- Allow: secondary language checks ---
      "cargo check*": "allow",
      "cargo test*": "allow",
      "go test*": "allow",

      // --- Allow: package inspection ---
      "uv pip list*": "allow",
      "cargo tree*": "allow",
      "go list*": "allow",
      "npm list*": "allow",

      // --- Deny: dangerous git ---
      "git pu*": "deny",
      "git fetch*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",

      // --- Deny: package modifications ---
      "pip *": "deny",
      "uv *": "ask",
      "cargo add*": "deny",
      "cargo install*": "deny",
      "cargo remove*": "deny",
      "go *": "deny",
      "npm *": "deny",

      // --- Deny: personal tools ---
      "chezmoi *": "deny",
      "mise *": "deny",
      "scoop *": "deny"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "deny",
          "general": "allow",
          "explore": "allow",
          "architect": "allow",
          "code-reviewer": "allow",
          "cve-scanner": "allow",
          "debugger": "allow",
          "polyglot": "allow",
          "python-documenter": "allow",
          "python-engineer": "allow",
          "python-reliability-reviewer": "allow",
          "python-test-engineer": "allow",
          "repo-map": "allow",
          "researcher": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "task": {
          "*": "deny",
          "explore": "allow",
          "general": "allow",
          "architect": "allow",
          "code-reviewer": "allow",
          "cve-scanner": "allow",
          "polyglot": "allow",
          "python-reliability-reviewer": "allow",
          "repo-map": "allow",
          "researcher": "allow"
        }
      }
    }
  }
}
